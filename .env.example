# =============================================
# KOVI Landing Page - Environment Variables
# =============================================
# HƯỚNG DẪN: Copy file này thành .env rồi điền giá trị thật
#   cp .env.example .env
# File .env KHÔNG được commit lên Git (đã có trong .gitignore)
# =============================================

# Resend API Key - lấy tại https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL production của website (không có dấu / ở cuối)
BASE_URL=https://your-domain.com

# Email nhận thông báo đơn hàng mới (admin)
ADMIN_EMAIL=your-email@gmail.com

# Flask environment
FLASK_ENV=production
